{
  "name": "listhen",
  "version": "1.10.0",
  "description": "👂 Elegant HTTP Listener",
  "license": "MIT",
  "repository": "unjs/listhen",
  "bin": {
    "listen": "./bin/listhen.mjs",
    "listhen": "./bin/listhen.mjs"
  },
  "files": [
    "dist",
    "lib",
    "bin",
    "cli.d.ts"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.mjs",
      "require": "./dist/cli.cjs"
    }
  },
  "scripts": {
    "build": "unbuild",
    "dev": "vitest",
    "lint": "oxlint . && oxfmt --check src test",
    "fmt": "oxlint --fix . && oxfmt src test",
    "listhen": "node ./scripts/listhen.mjs",
    "play": "node ./scripts/listhen.mjs -w ./playground --ws",
    "release": "pnpm test && pnpm build && changelogen --release && pnpm publish && git push --follow-tags",
    "test": "pnpm lint && vitest run --coverage"
  },
  "dependencies": {
    "@parcel/watcher-wasm": "^2.5.6",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "crossws": "^0.4.10",
    "defu": "^6.1.7",
    "get-port-please": "^3.2.0",
    "h3": "^1.15.11",
    "http-shutdown": "^1.2.2",
    "jiti": "^2.7.0",
    "node-forge": "^1.4.0",
    "pathe": "^2.0.3",
    "std-env": "^4.2.0",
    "tinyclip": "^0.1.15",
    "ufo": "^1.6.4",
    "untun": "^0.2.2",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/node-forge": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.10",
    "automd": "^0.4.3",
    "changelogen": "^0.6.2",
    "eslint-config-unjs": "^0.6.2",
    "ip-regex": "^5.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@parcel/watcher": "^2.5.6"
  },
  "peerDependenciesMeta": {
    "@parcel/watcher": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.15.1"
}
